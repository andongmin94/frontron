{
  "name": "create-frontron",
  "version": "0.13.3",
  "type": "module",
  "description": "Electron starter generator with React and Vite",
  "license": "MIT",
  "author": "안동민",
  "bin": {
    "create-frontron": "index.js"
  },
  "files": [
    "index.js",
    "template",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run --exclude __tests__/release-rehearsal.spec.ts",
    "test:release-smoke": "vitest run __tests__/release-rehearsal.spec.ts",
    "release:verify": "node ../release.mjs verify",
    "release:matrix-smoke": "node ../release.mjs matrix-smoke",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "version": "node ../release.mjs sync-version",
    "release": "node ../release.mjs publish"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andongmin94/frontron.git"
  },
  "bugs": {
    "url": "https://github.com/andongmin94/frontron/issues"
  },
  "homepage": "https://andongmin.com/frontron/",
  "dependencies": {
    "kolorist": "^1.8.0",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.10.13",
    "@types/prompts": "^2.4.9",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.0.7"
  }
}
