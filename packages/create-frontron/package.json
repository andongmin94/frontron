{
  "name": "create-frontron",
  "version": "0.11.2",
  "type": "module",
  "description": "Electron starter generator with React and Vite",
  "license": "MIT",
  "author": "안동민",
  "bin": {
    "create-frontron": "index.js"
  },
  "files": [
    "index.js",
    "template",
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run --exclude __tests__/release-rehearsal.spec.ts",
    "test:release-smoke": "vitest run __tests__/release-rehearsal.spec.ts",
    "release:verify": "cd ../frontron && npm run test:package-smoke && cd ../create-frontron && npm run test:release-smoke",
    "release:matrix-smoke": "node scripts/release-matrix-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "version": "node sync-version.js",
    "release": "npm run release:verify && cd ../frontron && npm publish && cd ../create-frontron && npm publish"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andongmin94/frontron.git"
  },
  "bugs": {
    "url": "https://github.com/andongmin94/frontron/issues"
  },
  "homepage": "https://frontron.andongmin.com",
  "dependencies": {
    "kolorist": "^1.8.0",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.10.13",
    "@types/prompts": "^2.4.9",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.0.7"
  }
}
