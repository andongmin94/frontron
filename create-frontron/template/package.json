{
  "name": "desktop-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "author": "Template Maintainers",
  "description": "Electron desktop app template with React and Vite",
  "productName": "__CREATE_APP_NAME__",
  "scripts": {
    "dev"       : "node scripts/tasks.mjs dev",
    "app"       : "node scripts/tasks.mjs app",
    "typecheck" : "node scripts/tasks.mjs typecheck",
    "build"     : "node scripts/tasks.mjs build",
    "lint"      : "node scripts/tasks.mjs lint"
  },
  "dependencies": {
    "@base-ui/react"             : "^1.3.0",
    "@fontsource-variable/geist" : "^5.2.8",
    "@tailwindcss/vite"          : "^4.2.2",
    "class-variance-authority"   : "^0.7.1",
    "clsx"                       : "^2.1.1",
    "lucide-react"               : "^0.577.0",
    "react"                      : "^19.2.4",
    "react-dom"                  : "^19.2.4",
    "tailwind-merge"             : "^3.5.0",
    "tailwindcss"                : "^4.2.2",
    "tw-animate-css"             : "^1.4.0"
  },
  "devDependencies": {
    "@types/node"          : "^26.1.1",
    "@types/react"         : "^19.2.14",
    "@types/react-dom"     : "^19.2.3",
    "@vitejs/plugin-react" : "^6.0.1",
    "electron"             : "^40.1.0",
    "electron-builder"     : "^26.0.12",
    "oxfmt"                : "^0.42.0",
    "oxlint"               : "^1.57.0",
    "typescript"           : "~6.0.2",
    "vite"                 : "^8.0.1"
  },
  "main": "dist/electron/main.js",
  "build": {
    "appId": "__CREATE_APP_ID__",
    "productName": "__CREATE_APP_NAME__",
    "copyright": "Copyright (c) Template Maintainers",
    "icon": "public/logo.svg",
    "win": {
      "target": [
        "msi",
        "portable"
      ]
    },
    "msi": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    },
    "npmRebuild": false,
    "files": [
      "dist{,/**/*}",
      "public{,/**/*}",
      "!node_modules{,/**/*}"
    ],
    "directories": {
      "output": "output"
    }
  }
}
