{
  "name": "frontron",
  "version": "0.11.2",
  "type": "module",
  "description": "Framework-first desktop app layer for existing web projects",
  "license": "MIT",
  "author": "andongmin",
  "bin": {
    "frontron": "index.js"
  },
  "files": [
    "index.js",
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "unbuild",
    "test": "vitest run --no-file-parallelism --exclude __tests__/package-smoke.spec.ts --exclude __tests__/runtime-smoke.spec.ts",
    "test:package-smoke": "vitest run --no-file-parallelism __tests__/package-smoke.spec.ts",
    "test:runtime-smoke": "vitest run --no-file-parallelism __tests__/runtime-smoke.spec.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andongmin94/frontron.git"
  },
  "bugs": {
    "url": "https://github.com/andongmin94/frontron/issues"
  },
  "homepage": "https://frontron.andongmin.com",
  "devDependencies": {
    "@types/node": "^24.10.13",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.0.7"
  },
  "dependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "koffi": "^2.15.2"
  }
}
