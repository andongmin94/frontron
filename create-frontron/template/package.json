{
  "name": "desktop-app",
  "version": "0.0.0",
  "type": "module",
  "author": "Template Maintainers",
  "description": "Electron desktop app template with React and Vite",
  "productName": "__CREATE_APP_NAME__",
  "scripts": {
    "dev": "vite",
    "app": "node src/electron/serve.ts --dev-app",
    "typecheck": "tsc -b && tsc -p tsconfig.electron.json",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json && electron-builder",
    "lint": "oxlint --fix src vite.config.ts && oxfmt ."
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.0.12",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.1"
  },
  "main": "dist/electron/main.js",
  "build": {
    "appId": "__CREATE_APP_ID__",
    "productName": "__CREATE_APP_NAME__",
    "copyright": "Copyright (c) Template Maintainers",
    "icon": "public/icon.ico",
    "win": {
      "target": [
        "msi",
        "portable"
      ]
    },
    "msi": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    },
    "files": [
      "dist{,/**/*}",
      "public{,/**/*}"
    ],
    "directories": {
      "output": "output"
    }
  }
}
